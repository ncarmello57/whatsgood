{
  "expo": {
    "name": "WhatsGood",
    "slug": "whatsgood",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5A623"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.whatsgood",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to take photos of meals.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select meal photos.",
        "NSLocationWhenInUseUsageDescription": "This app needs your location to tag restaurants you visit."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5A623"
      },
      "package": "com.yourname.whatsgood",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": []
  }
}
